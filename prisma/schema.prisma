generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceOrderStatus {
  OPEN
  CLOSED
  CANCELED
}

enum ServiceOrderChannel {
  LOCAL
  DELIVERY
  TAKEOUT
}

enum ProductUnit {
  KG
  UN
  L
  ML
  G
}

enum StockMovementType {
  IN
  OUT
  ADJUST
  SALE
}

enum StockMovementInputMode {
  UNIT
  PACKAGE
}

model AppSettings {
  id             String   @id @default("global")
  mealPriceCents Int      @default(2000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id             String             @id @default(cuid())
  name           String
  unit           ProductUnit        @default(UN)
  salePriceCents Int                @default(0)
  costCents      Int?
  quantity       Decimal            @default(0) @db.Decimal(12, 3)
  minQuantity    Decimal            @default(0) @db.Decimal(12, 3)
  isSellable     Boolean            @default(true)
  purchaseByPackage Boolean          @default(false)
  packageWeightKg   Decimal?         @db.Decimal(10, 3)
  categoryId     String?
  category       Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems     ServiceOrderItem[]
  movements      StockMovement[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model ServiceOrder {
  id             String                   @id @default(cuid())
  number         Int                      @unique @default(autoincrement())
  customerName   String?
  tableLabel     String?
  channel        ServiceOrderChannel      @default(LOCAL)
  status         ServiceOrderStatus       @default(OPEN)
  notes          String?
  subtotalCents  Int                      @default(0)
  discountCents  Int                      @default(0)
  surchargeCents Int                      @default(0)
  totalCents     Int                      @default(0)
  closedAt       DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  weightLines    ServiceOrderWeightLine[]
  mealLines      ServiceOrderMealLine[]
  items          ServiceOrderItem[]
}

model ServiceOrderWeightLine {
  id              String       @id @default(cuid())
  serviceOrderId  String
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  description     String       @default("Buffet self-service")
  weightKg        Decimal      @db.Decimal(10, 3)
  pricePerKgCents Int
  totalCents      Int
  createdAt       DateTime     @default(now())
}

model ServiceOrderMealLine {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  description    String       @default("Refeicao")
  quantity       Decimal      @db.Decimal(10, 3)
  unitPriceCents Int
  totalCents     Int
  createdAt      DateTime     @default(now())
}

model ServiceOrderItem {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  description    String
  quantity       Decimal      @db.Decimal(10, 3)
  unitPriceCents Int
  totalCents     Int
  createdAt      DateTime     @default(now())
}

model StockMovement {
  id             String            @id @default(cuid())
  productId      String
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  type           StockMovementType
  quantity       Decimal           @db.Decimal(12, 3)
  inputQuantity  Decimal?          @db.Decimal(12, 3)
  inputMode      StockMovementInputMode @default(UNIT)
  reason         String?
  serviceOrderId String?
  createdAt      DateTime          @default(now())
}
